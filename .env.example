# Datalake (shared with engine repo - for reading and optionally POSTing bars)
DATALAKE_URL=http://127.0.0.1:8888
DATALAKE_API_KEY=
DATALAKE_INGEST_PATH=/ingest

# MetaTrader 5 fetcher (scripts/mt5_fetch.py) - optional if terminal is
# already running and logged in. MT5_PATH points at terminal64.exe.
MT5_PATH=
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Tiingo fetcher (scripts/tiingo_fetch.py) - free tier at https://api.tiingo.com
# Used for single-name US equities where Yahoo rate-limits are unworkable.
TIINGO_API_KEY=
